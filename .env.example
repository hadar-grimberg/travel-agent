# LLM provider: "token" (Nebius per-token API, default) or "serverless" (dedicated endpoint)
TRAVEL_AGENT_LLM_PROVIDER=token

# Provider "token": Nebius per-token API
NEBIUS_API_KEY=...
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1/

# Provider "serverless": Nebius serverless dedicated endpoint
# (OpenAI-compatible URL; the endpoint ID is used as the model name)
NEBIUS_ENDPOINT_URL=
NEBIUS_ENDPOINT_ID=

# Optional: Tavily web search for live activity/restaurant discovery
TAVILY_API_KEY=tvly-...

# Optional: Geoapify Places for POI data (free tier at https://www.geoapify.com)
GEOAPIFY_API_KEY=

# Agent model (defaults to gpt-4o-mini for cost; use gpt-4o for higher quality)
TRAVEL_AGENT_MODEL=gpt-4o-mini
